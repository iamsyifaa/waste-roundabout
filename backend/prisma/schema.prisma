// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  FARMER
  COLLECTOR
  ADMIN
}

enum WastePostStatus {
  AVAILABLE
  BOOKED
  SOLD
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  EXPIRED
}

// --- MODELS ---

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  password     String
  role         Role          @default(FARMER)
  points       Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  wastePosts   WastePost[]
  transactions Transaction[]
  pointLogs    PointLog[]
  badges       UserBadge[]
}

model WasteCategory {
  id             String      @id @default(uuid())
  name           String      @unique
  description    String?
  basePricePerKg Float       @default(0.0)
  wastePosts     WastePost[]
}

model WastePost {
  id          String          @id @default(uuid())
  title       String
  description String
  imageUrl    String?
  weight      Float
  status      WastePostStatus @default(AVAILABLE)
  postedById  String
  postedBy    User            @relation(fields: [postedById], references: [id])
  categoryId  String
  category    WasteCategory   @relation(fields: [categoryId], references: [id])
  transaction Transaction?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Transaction {
  id              String            @id @default(uuid())
  wastePostId     String            @unique
  wastePost       WastePost         @relation(fields: [wastePostId], references: [id])
  collectorId     String
  collector       User              @relation(fields: [collectorId], references: [id])
  pointsAwarded   Int
  finalPrice      Float             @default(0.0)
  status          TransactionStatus @default(PENDING)
  paymentStatus   PaymentStatus     @default(UNPAID)
  snapToken       String?
  midtransOrderId String?           @unique
  createdAt       DateTime          @default(now())
}

model PointLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  points      Int
  description String
  createdAt   DateTime @default(now())
}

model Badge {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  description String
  icon        String      @default("🏆")
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, badgeId])
}